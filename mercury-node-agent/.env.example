# Mercury Node Agent — Environment Variables
#
# Required:
NODE_AGENT_TOKEN=           # Shared secret for control plane authentication
NODE_AGENT_BASE_DOMAIN=mercury.app  # Base domain for agent subdomains
ACME_EMAIL=admin@example.com        # Email for Let's Encrypt certificates
HETZNER_DNS_API_TOKEN=      # Hetzner DNS API token for wildcard TLS

# Optional:
NODE_AGENT_PORT=9090                 # Node agent HTTP port
NODE_AGENT_DOCKER_NETWORK=mercury-net # Docker network name
NODE_AGENT_DEFAULT_MEMORY_MB=512     # Default memory limit per agent (MB)
NODE_AGENT_DEFAULT_CPUS=0.5          # Default CPU limit per agent
