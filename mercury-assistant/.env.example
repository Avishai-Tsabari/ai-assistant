# Secrets and credentials only. Non-secret defaults can live in mercury.yaml
# (see mercury.example.yaml in this directory). MERCURY_* here overrides YAML.

# ─── Provider / search API keys (at least one model provider required) ─
# MERCURY_ANTHROPIC_API_KEY=
# MERCURY_OPENAI_API_KEY=
MERCURY_GEMINI_API_KEY=
MERCURY_GROQ_API_KEY=
MERCURY_OPENROUTER_API_KEY=
MERCURY_MISTRAL_API_KEY=
# MERCURY_HF_TOKEN=

# MERCURY_BRAVE_API_KEY=

# ─── Security ───────────────────────────────────────────────────────────
# MERCURY_API_SECRET=
# MERCURY_CHAT_API_KEY=

# ─── Platform tokens (uncomment what you enable in mercury.yaml) ──────
MERCURY_TELEGRAM_BOT_TOKEN=
# MERCURY_TELEGRAM_WEBHOOK_SECRET_TOKEN=
# MERCURY_SLACK_BOT_TOKEN=
# MERCURY_SLACK_SIGNING_SECRET=
# MERCURY_DISCORD_BOT_TOKEN=
# MERCURY_WHATSAPP_* — see mercury-fork docs/setup-whatsapp.md

# Optional: dedicated key for LLM context classifier (else uses provider keys)
# MERCURY_CONTEXT_CLASSIFIER_API_KEY=

# Optional: force config path or disable file-based config
# MERCURY_CONFIG_FILE=none

# ─── Env-only (not in mercury.yaml / loadConfig) ───────────────────────
# Keep these here if you use the feature; they are not merged from YAML.

# Web browser / pinchtab stealth: light | full
# MERCURY_BRIDGE_STEALTH=full

# Napkin KB distillation interval (ms); 0 or unset = disabled
# MERCURY_KB_DISTILL_INTERVAL_MS=0

# Discord interactions API (in addition to MERCURY_DISCORD_BOT_TOKEN)
# MERCURY_DISCORD_PUBLIC_KEY=
# MERCURY_DISCORD_APPLICATION_ID=

# Teams (when MERCURY_ENABLE_TEAMS=true in mercury.yaml)
# MERCURY_TEAMS_APP_ID=
# MERCURY_TEAMS_APP_PASSWORD=
# MERCURY_TEAMS_APP_TENANT_ID=
# MERCURY_TEAMS_APP_TYPE=SingleTenant

# Container / extensions (advanced)
# MERCURY_EXT_SYSTEM_PROMPT=
# MERCURY_DENIED_CLIS=
# MERCURY_DISABLE_BUBBLEWRAP=
