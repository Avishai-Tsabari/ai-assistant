# ─── Auth Keys ─────────────────────────────────────────────────────────
# Required: one provider key (MERCURY_ prefix stripped when passed to container)
# MERCURY_ANTHROPIC_API_KEY=
# MERCURY_OPENAI_API_KEY=
MERCURY_GEMINI_API_KEY=

# ─── Identity ──────────────────────────────────────────────────────────
MERCURY_BOT_USERNAME=mercury
MERCURY_PORT=3000
MERCURY_TRIGGER_PATTERNS=@Mercury,Mercury,@bishi_assistant_bot,bishi_assistant_bot

# ─── Model ─────────────────────────────────────────────────────────────
# MERCURY_MODEL_PROVIDER=google
# MERCURY_MODEL=gemini-2.5-flash

# Groq (native provider)
MERCURY_MODEL_PROVIDER=groq
MERCURY_GROQ_API_KEY=gsk_your_groq_api_key_here
MERCURY_MODEL=llama-3.3-70b-versatile

# Optional fallback when primary model fails (e.g. quota exceeded)
# MERCURY_MODEL_FALLBACK_PROVIDER=openai
# MERCURY_MODEL_FALLBACK=gpt-4o-mini

# Compaction: max recent tokens to keep when compacting (pi default 20k).
# Use ~4000 for Groq 8b (6k TPM limit) to avoid "Request too large" errors.
# MERCURY_COMPACT_KEEP_RECENT_TOKENS=4000

# Conditional context: use minimal session for standalone prompts (reduces tokens).
# MERCURY_CONDITIONAL_CONTEXT_ENABLED=true
# MERCURY_CONTEXT_CLASSIFIER=heuristic   # heuristic (no API cost) or llm (higher accuracy)
# MERCURY_CONTEXT_CLASSIFIER_PROVIDER=  # e.g. groq, google. Defaults to MERCURY_MODEL_PROVIDER
# MERCURY_CONTEXT_CLASSIFIER_MODEL=     # e.g. llama-3.3-70b-versatile, gemini-2.5-flash. Defaults to MERCURY_MODEL
# MERCURY_CONTEXT_CLASSIFIER_API_KEY=   # optional; dedicated key for classifier (overrides provider-specific keys)

# ─── Runtime ───────────────────────────────────────────────────────────
MERCURY_DATA_DIR=.mercury
MERCURY_MAX_CONCURRENCY=2
MERCURY_LOG_LEVEL=info

# ─── Agent Container Image ─────────────────────────────────────────────
# Presets (from GitHub Container Registry):
#   ghcr.io/michaelliv/mercury-agent:latest   - Full: Node, Python, Go, git (~2.8GB)
#   ghcr.io/michaelliv/mercury-agent:minimal  - Lightweight: Bun + pi + browser (~1.9GB)
# Or build locally: ./container/build.sh all
# Custom images must have: bun, pi, mrctl
# See docs/container-lifecycle.md for custom image requirements
MERCURY_AGENT_IMAGE=ghcr.io/michaelliv/mercury-agent:latest
# MERCURY_AGENT_IMAGE=mercury-agent:latest - if built locally

# Optional: admin caller IDs (comma-separated)
# MERCURY_ADMINS=

# ─── Container Passthrough ─────────────────────────────────────────────
# All MERCURY_* vars are passed to containers with prefix stripped.
# Example: MERCURY_MY_API_KEY=xxx becomes MY_API_KEY=xxx in container

# ─── WhatsApp Ingress ──────────────────────────────────────────────────
MERCURY_ENABLE_WHATSAPP=false # set to true to enable WhatsApp ingress, if false can be used only for testing using:mercury chat command

# ─── Slack Ingress ─────────────────────────────────────────────────────
MERCURY_ENABLE_SLACK=false
# MERCURY_SLACK_BOT_TOKEN=
# MERCURY_SLACK_SIGNING_SECRET=

# ─── Teams Ingress ──────────────────────────────────────────────────────
MERCURY_ENABLE_TEAMS=false
# MERCURY_TEAMS_APP_ID=
# MERCURY_TEAMS_APP_PASSWORD=
# MERCURY_TEAMS_APP_TENANT_ID=
# MERCURY_TEAMS_APP_TYPE=SingleTenant

# ─── Discord Ingress ───────────────────────────────────────────────────
MERCURY_ENABLE_DISCORD=false
# MERCURY_DISCORD_BOT_TOKEN=

# ─── Web Browser (web-search + Pinchtab) ─────────────────────────────────
# web-search: Brave Search API key (search.brave.com; ~$5/1k queries, $5 monthly credits)
# MERCURY_BRAVE_API_KEY=
# Stealth reduces CAPTCHA for pinchtab. Default is "full"; use "light" to disable.
# MERCURY_BRIDGE_STEALTH=full

# ─── Telegram Ingress ─────────────────────────────────────────────────
MERCURY_ENABLE_TELEGRAM=true
MERCURY_TELEGRAM_BOT_TOKEN=
# MERCURY_TELEGRAM_WEBHOOK_SECRET_TOKEN=