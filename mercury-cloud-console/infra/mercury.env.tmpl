# Rendered on the agent VPS — do not commit real values
# HTTP server (see mercury-fork config-file.ts → MERCURY_PORT)
MERCURY_PORT=8787

# Required: at least one model provider
MERCURY_ANTHROPIC_API_KEY={{MERCURY_ANTHROPIC_API_KEY}}

# Dashboard + console API protection (set before first boot)
MERCURY_API_SECRET={{MERCURY_API_SECRET}}

# At least one chat adapter is required for mercury run; WhatsApp needs no token until you pair (dashboard).
MERCURY_ENABLE_WHATSAPP=true

# Agent container image (pulled during provisioning)
MERCURY_AGENT_IMAGE={{MERCURY_AGENT_IMAGE}}

# Optional platforms (uncomment / set as needed)
# MERCURY_TELEGRAM_BOT_TOKEN=
# MERCURY_SLACK_BOT_TOKEN=
# MERCURY_DISCORD_BOT_TOKEN=

# Extension-specific (from catalog required_env)
{{OPTIONAL_ENV_LINES}}
