# ─── Hetzner Cloud (Phase 1 provisioning CLI) ─────────────────────────
HETZNER_API_TOKEN=
# Optional: numeric SSH key id from Hetzner console (comma-separated for multiple)
HETZNER_SSH_KEY_IDS=
HETZNER_SERVER_TYPE=cx33
# Hetzner Docker CE app image — Docker pre-installed (see https://docs.hetzner.com/cloud/apps/)
HETZNER_IMAGE=docker-ce
HETZNER_LOCATION=nbg1

# Base domain for agent hostnames (e.g. agents.example.com) — DNS A record per server or wildcard
BASE_DOMAIN=

# Hetzner DNS API token — for Traefik wildcard TLS certs (separate from Cloud API token)
HETZNER_DNS_API_TOKEN=

# Hetzner DNS: zone id for BASE_DOMAIN (optional; skip if you use wildcard DNS elsewhere)
HETZNER_DNS_ZONE_ID=

# ACME / Let's Encrypt email for TLS certificate registration
ACME_EMAIL=

# JSON file written by provision.ts and read by health-check.ts
AGENTS_JSON_PATH=./data/agents.json

# GitHub `owner/repo` (default branch) that contains `examples/extensions/<slug>/` for catalog extensions.
# Public Michaelliv/mercury often does NOT ship `examples/` on main — use a fork that includes it, or set extensionIds to [] in the request JSON.
MERCURY_EXTENSIONS_REPO=Michaelliv/mercury

# Docker image for the Mercury agent container (built from your mercury-fork).
# Provision will pull this on the VPS and set MERCURY_AGENT_IMAGE in the agent .env.
MERCURY_AGENT_IMAGE=ghcr.io/michaelliv/mercury-agent:latest

# GHCR personal access token with read:packages scope (required if the image is private).
# Used by cloud-init to `docker login ghcr.io` on the VPS before pulling.
GHCR_TOKEN=
GHCR_USERNAME=

# ─── Control plane web (Phase 2) ───────────────────────────────────────
DATABASE_URL=file:./data/console.db
AUTH_URL=http://localhost:3131
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Envelope encryption for stored user API keys (32-byte hex = 64 chars)
CONSOLE_ENCRYPTION_MASTER_KEY=

# Usage alert email notifications (via Resend)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@example.com
